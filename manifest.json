{
  "manifest_version": 3,
  "name": "Copy YouTube Source",
  "version": "1.0",

  "description": "Copies a YouTube video's name and link and format both to the Markdown syntax I use on my personal notes",

  "icons": {
    "48": "icons/ic--baseline-content-copy-dark.png"
  },

  "permissions": ["activeTab", "scripting", "clipboardWrite"],

  "browser_specific_settings": {
    "gecko": {
      "id": "th3worst4@myBasement.cp_yt_source",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_icon": "icons/ic--baseline-content-copy-dark.png",
    "theme_icons": [
      {
        "light": "icons/ic--baseline-content-copy-light.png",
        "dark": "icons/ic--baseline-content-copy-dark.png",
        "size": 48
      }
    ],
    "default_title": "Copy YT Link",
    "default_popup": "cp-yt-link.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["none"],
      "matches": ["*://*.youtube.com/watch?*"]
    }
  ]
}
